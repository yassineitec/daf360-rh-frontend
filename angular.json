{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"cli": {
		"packageManager": "npm",
		"analytics": "88a48f35-8faa-466b-934a-eaae46580409"
	},
	"newProjectRoot": "projects",
	"projects": {
		"daf360-rh-frontend": {
			"projectType": "application",
			"schematics": {},
			"root": "",
			"sourceRoot": "src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular-architects/native-federation:build",
					"options": {
						"target": "daf360-rh-frontend:esbuild",
						"federationConfig": "federation.config.js"
					},
					"configurations": {
						"production": {
							"target": "daf360-rh-frontend:esbuild:production"
						},
						"development": {
							"target": "daf360-rh-frontend:esbuild:development"
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular-architects/native-federation:build",
					"options": {
						"target": "daf360-rh-frontend:serve-original",
						"dev": true
					}
				},
				"test": {
					"builder": "@angular/build:unit-test"
				},
				"esbuild": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist/daf360-rh-frontend",
						"baseHref": "/rh/",
						"index": "src/index.html",
						"browser": "src/main.ts",
						"polyfills": ["zone.js"],
						"tsConfig": "tsconfig.app.json",
						"assets": [
							{
								"glob": "**/*",
								"input": "public",
								"output": "."
							}
						],
						"styles": [
							"src/styles.css"
						]
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve-original": {
					"builder": "@angular/build:dev-server",
					"options": {
						"buildTarget": "daf360-rh-frontend:esbuild:development",
						"port": 4203
					},
					"configurations": {
						"production": {
							"buildTarget": "daf360-rh-frontend:esbuild:production"
						},
						"development": {
							"buildTarget": "daf360-rh-frontend:esbuild:development"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		}
	}
}